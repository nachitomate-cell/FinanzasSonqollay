rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Cada usuario (UID anónimo o autenticado) solo accede a sus propios datos.
    // El comodín cubre TODAS sus subcolecciones: movimientos, categorias,
    // recurrentes, cuentas, fcmTokens, etc.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
